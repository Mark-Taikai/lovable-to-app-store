<!-- INFO.PLIST ADDITIONS — add these inside the root <dict> of ios/App/App/Info.plist -->
<!-- These apply to every app shipped with this plugin -->

<!-- Bypass Apple export compliance dialog for every build.
     Apps using only standard HTTPS/TLS qualify for this exemption.
     Without this, every TestFlight upload shows "Missing Compliance" requiring manual dismissal. -->
<key>ITSAppUsesNonExemptEncryption</key>
<false/>

<!-- Push notifications (required for OneSignal) -->
<key>NSUserNotificationUsageDescription</key>
<string>We'll send you important updates about your account.</string>

<!-- Required for OneSignal background push delivery -->
<key>UIBackgroundModes</key>
<array>
  <string>remote-notification</string>
</array>

<!-- App display name (what appears under the icon on home screen) -->
<!-- Replace {{APP_DISPLAY_NAME}} with e.g. "GameChime" -->
<key>CFBundleDisplayName</key>
<string>{{APP_DISPLAY_NAME}}</string>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- ALWAYS ADD: location usage descriptions (preempts ITMS-90683)          -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- Capacitor plugins like @bglocation/capacitor or onesignal-cordova-plugin
     reference CoreLocation APIs in their compiled binary even when the app
     doesn't actually use location. Apple flags missing purpose strings via
     ITMS-90683 emails after upload. The permission dialog only appears if
     code actually calls CLLocationManager — these strings are harmless
     when unused. See references/10-build-gotchas-addendum.md.

     ⚠️ IF THIS APP ACTUALLY USES LOCATION (uses @capacitor/geolocation,
     reverse geocoding, geofencing, or any "find my X" / "near me" feature),
     REPLACE these placeholder strings with a specific, user-facing reason.
     Example: "We use your location to show restaurants near you." Apple
     reviewers reject vague or contradictory strings under guideline 5.1.1
     (e.g. shipping with "this app does not actively use your location"
     while your code calls CLLocationManager will fail review). The strings
     below are safe ONLY for apps that don't read location at runtime. -->
<key>NSLocationWhenInUseUsageDescription</key>
<string>This app does not actively use your location.</string>
<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
<string>This app does not actively use your location.</string>
<key>NSLocationAlwaysUsageDescription</key>
<string>This app does not actively use your location.</string>

